{
  "name": "uw-course-finder",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Visualize a course path to your UW degree: enter courses you've taken and your target major, and see a quarter-by-quarter plan and an interactive prerequisite mind map.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "node scripts/run-tests.mjs",
    "data": "python3 scripts/build_data.py"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "esbuild": "^0.21.5",
    "jsdom": "^29.1.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
